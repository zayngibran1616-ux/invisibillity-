-- Core
local SKY = CFrame.new(-9.69, 600, 184.15)
local LOBBY = CFrame.new(-9.69, 291.64, 184.15)
local LOW_HP = 35
local SAFE_HP = 60
local skyMode = true
local enabled = false

local function setBtn(on)
	btn.Text = on and "AUTOFARM ON" or "AUTOFARM OFF"
	if on then
		btn.BackgroundColor3 = Color3.fromRGB(35, 120, 60)
	else
		btn.BackgroundColor3 = Color3.fromRGB(100, 40, 40)
	end
end

local function setModeBtn()
	modeBtn.Text = skyMode and "SKY" or "LOBBY"
	modeBtn.BackgroundColor3 = skyMode and Color3.fromRGB(30, 30, 80) or Color3.fromRGB(50, 40, 20)
end

local function safe()
	return skyMode and SKY or LOBBY
end

local function setStatus(t)
	statusText.Text = t
end

local function root()
	local ok, char = pcall(function() return lp.Character end)
	if not ok or not char then return nil end
	local ok2, r = pcall(function() return char:FindFirstChild("HumanoidRootPart") end)
	if not ok2 or not r then return nil end
	return r
end

local function tp(cf)
	pcall(function()
		local r = root()
		if r then r.CFrame = cf end
	end)
end

local function active()
	local da = ReplicatedStorage:FindFirstChild("DisasterActive")
	return da and da.Value == true
end

local function hp()
	local ok, char = pcall(function() return lp.Character end)
	if not ok or not char then return 100 end
	local ok2, hum = pcall(function() return char:FindFirstChildOfClass("Humanoid") end)
	if not ok2 or not hum then return 100 end
	return hum.Health
end

-- Noclip always on
task.spawn(function()
	while true do
		pcall(function()
			local char = lp.Character
			if not char then return end
			local hum = char:FindFirstChildOfClass("Humanoid")
			if not hum then return end
			hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
			hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
			for _, p in ipairs(char:GetDescendants()) do
				if p:IsA("BasePart") then
					p.CanCollide = false
				end
			end
		end)
		task.wait(0.1)
	end
end)

local function collect()
	local h = hp()
	if h <= LOW_HP then
		tp(SKY)
		setStatus("HP low (" .. math.floor(h) .. ") - hiding")
		return
	end
	setStatus("Collecting beacons...")
	while enabled and active() do
		if hp() <= LOW_HP then
			tp(SKY)
			setStatus("HP low (" .. math.floor(hp()) .. ") - hid in sky")
			break
		end
		pcall(function()
			local folder = workspace:FindFirstChild("ClockRemnants")
			if not folder then return end
			for _, m in ipairs(folder:GetChildren()) do
				if not enabled or not active() then break end
				if hp() <= LOW_HP then break end
				if m:IsA("Model") and m:GetAttribute("IsClockRemnant") == true then
					local n = m.Name:lower()
					if n:find("unactivated") or (not n:find("activated") and not n:find("idle")) then
						local parts = {m:FindFirstChild("ImpactEffect"), m:FindFirstChild("Ray1"), m:FindFirstChild("Ray2")}
						for _, p in ipairs(parts) do
							if p and p:IsA("BasePart") then
								tp(CFrame.new(p.Position))
								task.wait(0.15)
							end
						end
						local cframe, size = m:GetBoundingBox()
						if cframe then
							tp(cframe)
							task.wait(0.15)
						end
					end
				end
			end
			for _, c in ipairs(folder:GetChildren()) do
				if c:IsA("BasePart") and c.Name:lower():find("hitbox") then
					tp(CFrame.new(c.Position))
					task.wait(0.15)
				end
			end
		end)
		tp(SKY)
		task.wait(2)
	end
	setStatus("Round: surviving...")
end

task.spawn(function()
	while true do
		if enabled and active() then
			if hp() >= SAFE_HP then
				collect()
			else
				tp(SKY)
				setStatus("HP too low (" .. math.floor(hp()) .. ") - waiting")
				task.wait(2)
			end
		else
			pcall(function()
				local s = ReplicatedStorage:FindFirstChild("Status")
				if s and tostring(s.Value):find("Intermission") then
					tp(safe())
					setStatus("Intermission")
				end
			end)
			setStatus("Waiting for round...")
		end
		task.wait(1)
	end
end)

lp.CharacterAdded:Connect(function()
	task.wait(1.5)
	if enabled and active() then
		tp(safe())
		setStatus("Rejoined - collecting")
	end
end)

local bs = ReplicatedStorage:FindFirstChild("CR_BeaconSpawned")
if bs then
	bs.OnClientEvent:Connect(function()
		if enabled and active() then
			task.spawn(collect)
		end
	end)
end

local aa = ReplicatedStorage:FindFirstChild("CR_AllBeaconsActivated")
if aa then
	aa.OnClientEvent:Connect(function()
		tp(safe())
		setStatus("All beacons done")
	end)
end

btn.MouseButton1Click:Connect(function()
	enabled = not enabled
	setBtn(enabled)
	if enabled then
		setStatus("Enabled - waiting for round...")
		if active() then
			task.spawn(function()
				task.wait(2)
				collect()
			end)
		end
	else
		setStatus("Disabled")
	end
end)

modeBtn.MouseButton1Click:Connect(function()
	skyMode = not skyMode
	setModeBtn()
	tp(safe())
end)

setBtn(false)
setModeBtn()
setStatus("Click to enable")
