local player = game.Players.LocalPlayer
local invisible = false

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "InvisGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 150, 0, 40)
button.Position = UDim2.new(0.5, -75, 0, 10)
button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
button.BorderColor3 = Color3.fromRGB(100, 100, 100)
button.Text = "Invisibility: OFF"
button.TextColor3 = Color3.new(1, 1, 1)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.Parent = screenGui

local function toggle()
    invisible = not invisible
    local c = player.Character
    if not c then return end
    for _, v in c:GetDescendants() do
        if v:IsA("BasePart") then v.Transparency = invisible and 1 or 0 end
        if v:IsA("Decal") or v:IsA("Face") then v.Transparency = invisible and 1 or 0 end
    end
    pcall(function()
        local h = c:FindFirstChild("Head")
        if h then
            local tag = h:FindFirstChild("BillboardGui")
            if tag then tag.Enabled = not invisible end
        end
    end)
    button.Text = invisible and "Invisibility: ON" or "Invisibility: OFF"
    button.BackgroundColor3 = invisible and Color3.fromRGB(0, 80, 0) or Color3.fromRGB(30, 30, 30)
end

button.MouseButton1Click:Connect(toggle)

player.CharacterAdded:Connect(function(c)
    if invisible then
        c:WaitForChild("HumanoidRootPart")
        task.wait(0.5); toggle(); toggle()
    end
end)
