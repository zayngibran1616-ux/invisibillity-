local spinning = false
local angle = 0
local orbitDist = 5
local targetPlayer = nil
local useNearest = true

toggle.MouseButton1Click:Connect(function()
	spinning = not spinning
	toggle.BackgroundColor3 = spinning and Color3.fromRGB(50, 180, 50) or Color3.fromRGB(60, 60, 60)
	toggle.Text = spinning and "Spin [ON]" or "Spin [OFF]"
	if not spinning then
		status.Text = "Target: none"
	end
end)

nearestBtn.MouseButton1Click:Connect(function()
	useNearest = true
	targetPlayer = nil
	status.Text = "Target: nearest"
end)

local function findDisplayName(name)
	local lower = name:lower()
	for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
		if p ~= player then
			if p.DisplayName:lower():find(lower) or p.Name:lower():find(lower) then
				return p
			end
		end
	end
	return nil
end

box.FocusLost:Connect(function(enter)
	if enter and box.Text ~= "" and box.Text ~= "Display Name" then
		local found = findDisplayName(box.Text)
		if found then
			targetPlayer = found
			useNearest = false
			status.Text = "Target: " .. found.DisplayName
		else
			status.Text = "Player not found!"
		end
	end
end)

run.RenderStepped:Connect(function()
	if not spinning then return end
	
	local target
	if useNearest or not targetPlayer then
		local nearest, nearestDist = nil, math.huge
		for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
			if p ~= player then
				local char = p.Character
				local root = char and char:FindFirstChild("HumanoidRootPart")
				if root then
					local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
					local origin = myRoot and myRoot.Position or camera.CFrame.Position
					local dist = (root.Position - origin).Magnitude
					if dist < nearestDist then
						nearest = p
						nearestDist = dist
					end
				end
			end
		end
		target = nearest
	else
		target = targetPlayer
	end
	
	if not target then
		status.Text = "Target: none"
		return
	end
	
	local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
	if not targetRoot then
		status.Text = "Target: no root"
		return
	end
	
	local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end
	
	local dist = (targetRoot.Position - myRoot.Position).Magnitude
	status.Text = "Target: " .. target.DisplayName .. " (" .. math.floor(dist) .. ")"
	
	angle = angle + 0.03
	
	local x = math.cos(angle) * orbitDist
	local z = math.sin(angle) * orbitDist
	local targetPos = targetRoot.Position
	
	myRoot.CFrame = CFrame.new(
		targetPos.X + x,
		targetPos.Y,
		targetPos.Z + z
	)
	myRoot.CFrame = CFrame.lookAt(myRoot.Position, targetPos)
end)
