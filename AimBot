local player = game.Players.LocalPlayer
local uis = game:GetService("UserInputService")
local cam = workspace.CurrentCamera
local enabled, aimTarget = false, nil

local function getNearest()
    local nearest, nearestDist = nil, math.huge
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    for _, plr in game.Players:GetPlayers() do
        if plr == player then continue end
        local c = plr.Character
        if not c or not c:FindFirstChild("Head") then continue end
        local hum = c:FindFirstChild("Humanoid")
        if hum and hum.Health <= 0 then continue end
        local _, on = cam:WorldToViewportPoint(c.Head.Position)
        if not on then continue end
        local d = (c.Head.Position - char.HumanoidRootPart.Position).Magnitude
        if d < nearestDist then nearest, nearestDist = plr, d end
    end
    return nearest
end

uis.InputBegan:Connect(function(i, g)
    if g then return end
    if i.UserInputType == Enum.UserInputType.MouseButton2 then
        local t = getNearest()
        if t then aimTarget, enabled = t, true end
    end
end)
uis.InputEnded:Connect(function(i, g)
    if g then return end
    if i.UserInputType == Enum.UserInputType.MouseButton2 then
        enabled, aimTarget = false, nil
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    if not enabled or not aimTarget then return end
    local c = aimTarget.Character
    if not c or not c:FindFirstChild("Head") then enabled, aimTarget = false, nil; return end
    cam.CFrame = CFrame.lookAt(cam.CFrame.Position, c.Head.Position)
end)
