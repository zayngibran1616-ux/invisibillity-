local Players = game:GetService("Players")
local lp = Players.LocalPlayer

-- Infinite Stamina
local charSettings = require(game.ReplicatedStorage:FindFirstChild("CharacterSettings", true))
charSettings.StaminaDrain = 0
charSettings.StaminaMax = math.huge

-- Build room -> position map from LevelChanger parts
local roomPositions = {}
local changers = workspace:FindFirstChild("Stuff"):FindFirstChild("LevelChangers")
for _, v in ipairs(changers:GetChildren()) do
    if v:IsA("BasePart") then
        local name = v:GetAttribute("LevelName")
        if name and not roomPositions[name] then
            roomPositions[name] = v.Position + Vector3.new(0, 3, 0)
        end
    end
end

-- Teleport function
local function teleportTo(roomName)
    local pos = roomPositions[roomName]
    if not pos then return end
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(pos)
    end
end

