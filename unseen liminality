local rooms = {"Lobby","PoolRooms","Hotel","DreamCore","Pipedreams","Desolate Office","LiminalHome","EmptyLounge","Frutiger","Cheated","LevelSelector"}

local y = 0
for _, room in ipairs(rooms) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.Position = UDim2.new(0, 5, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Text = room
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.BorderSizePixel = 0
    btn.Parent = scrolling

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    btn.MouseButton1Click:Connect(function()
        local level = lp:FindFirstChild("Level")
        if level then level.Value = room end
        teleportTo(room)
    end)

    y = y + 40
    scrolling.CanvasSize = UDim2.new(0, 0, 0, y + 5)
end
